{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev-frontend",
      "type": "shell",
      "command": "npx",
      "args": ["vite", "--port", "5173"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "Local:"
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    }
  ]
}
